# ─────────────────────────────────────────────────────────────
# Engosoft HR — configuration (all optional; sensible defaults ship in code)
# Copy to `.env` and adjust. Everything runs client-side (no backend).
# ─────────────────────────────────────────────────────────────

# The Google Sheet that feeds the dashboard (must be shared "Anyone with the link → Viewer").
VITE_SHEET_ID=12n8WoP01MihoviW-jNlx5TajTr6Qy5AAOfHnFsv-A08

# Auto-refresh interval in seconds (how often the dashboard re-reads the sheet).
VITE_REFRESH_SECONDS=60

# OPTIONAL — a Google API key with the "Google Sheets API" enabled.
# When set, the dashboard AUTO-DISCOVERS every tab in the sheet (new monthly tabs
# appear automatically). Without it, the tabs listed in src/config/sheet.ts are used.
# Restrict the key to the Sheets API + your site's referrer before shipping.
VITE_GSHEET_API_KEY=
