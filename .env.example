# ─────────────────────────────────────────────────────────────
# Engosoft HR — configuration
# Copy to `.env` and fill in. Everything runs client-side; the only server-side
# piece is the Apps Script bound to the spreadsheet.
# ─────────────────────────────────────────────────────────────

# ── Reading ──────────────────────────────────────────────────
# The spreadsheet that feeds the dashboard.
# Must be shared "Anyone with the link → Viewer" for the public read to work.
VITE_SHEET_ID=12n8WoP01MihoviW-jNlx5TajTr6Qy5AAOfHnFsv-A08

# How often each open tab is re-read, in seconds.
VITE_REFRESH_SECONDS=90

# ── Writing (optional — without it the dashboard is read-only) ─
# Deploy apps-script/Code.gs as a Web App (Execute as: Me, Access: Anyone) and
# paste its /exec URL here, plus the same secret you set as the API_TOKEN script
# property.
#
# The token is visible to anyone who opens the site, so it is a "who may write"
# key, not a secret. Keep the site itself private, and rotate the token by
# changing the script property and this value together.
VITE_WRITE_API_URL=
VITE_WRITE_API_TOKEN=

# ── Salary passcode ──────────────────────────────────────────
# SHA-256 of the passcode, lowercase hex. Never put the passcode itself here.
# Generate it with:
#   python -c "import hashlib,sys; print(hashlib.sha256(sys.argv[1].encode()).hexdigest())" "YOUR-PASSCODE"
# Leave empty and the Salaries page stays permanently locked.
VITE_SALARY_PASS_HASH=

# ── Local preview (dev server only) ──────────────────────────
# `local` reads data/csv/ instead of Google Sheets, so the dashboard can be
# demoed before the sheet is populated. Ignored in a production build.
VITE_DATA_MODE=
